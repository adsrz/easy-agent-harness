# Root admission boundary: unexpected top-level drops stay out of Git by default.
/*
!/.github/
!/agent/
!/docs/
!/tools/
!/.gitattributes
!/.gitignore
!/AGENTS.md
!/AI_CONTEXT.md
!/ai-context.json
!/CHANGELOG.md
!/CONTRIBUTING.md
!/LICENSE
!/README.md
!/README.zh-CN.md
!/ROADMAP.md
!/system.md
!/task-router.json

# OS / editor
.DS_Store
Thumbs.db
Desktop.ini

# Python / caches
__pycache__/
*.pyc
.ruff_cache/
.cache/

# Local artifacts
artifacts/

# Temporary files
*.tmp
*.temp
*.log

# Private overrides
.study-local/
